generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TourPackage {
  id            String   @id @default(uuid())
  slug          String   @unique
  title         String
  titleEn       String?
  description   String
  descriptionEn String?
  type          String
  category      String
  destination   String
  destinationEn String?
  duration      String
  durationEn    String?
  image         String
  price         Int
  priceDiscount Int?
  minPax        Int      @default(1)
  maxPax        Int?
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  badge         String?
  highlights    String[]
  highlightsEn  String[]
  includes      String[]
  includesEn    String[]
  excludes      String[]
  excludesEn    String[]
  itinerary     Json?
  terms         Json?
  status        String   @default("active")
  featured      Boolean  @default(false)
  hasDetail     Boolean  @default(false)
  whatsappText  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type, category, status])
  @@index([slug])
}

model Destination {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  nameEn        String?
  country       String
  countryEn     String?
  category      String
  image         String
  description   String
  descriptionEn String?
  packageCount  Int      @default(0)
  featured      Boolean  @default(false)
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category, status])
}

model Testimonial {
  id          String   @id @default(uuid())
  name        String
  location    String
  packageName String
  rating      Float    @default(5)
  comment     String
  commentEn   String?
  date        String
  avatar      String?
  status      String   @default("active")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, featured])
}

model FAQ {
  id         String   @id @default(uuid())
  question   String
  questionEn String?
  answer     String
  answerEn   String?
  category   String?
  order      Int      @default(0)
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, order])
}

model HeroSlide {
  id         String   @id @default(uuid())
  title      String
  titleEn    String?
  subtitle   String
  subtitleEn String?
  image      String
  order      Int      @default(0)
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, order])
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String
  group     String?
  label     String
  labelEn   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([group])
}

model Feature {
  id            String   @id @default(uuid())
  title         String
  titleEn       String?
  description   String
  descriptionEn String?
  icon          String
  order         Int      @default(0)
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, order])
}

model Article {
  id          String    @id @default(uuid())
  slug        String    @unique
  title       String
  titleEn     String?
  excerpt     String
  excerptEn   String?
  content     String
  contentEn   String?
  image       String
  category    String
  tags        String[]
  author      String
  status      String    @default("draft")
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([slug])
}

model TermsCondition {
  id        String   @id @default(uuid())
  title     String
  titleEn   String?
  content   String[]
  contentEn String[]
  order     Int      @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, order])
}

// TripSchedule: jadwal keberangkatan untuk open trip dan private trip
// Digunakan oleh halaman open-trip, private-trip, dan admin dashboard
model TripSchedule {
  id               String    @id @default(uuid())
  packageId        String
  // Fields untuk open trip / private trip (data.ts style)
  destinasi        String    @default("")
  durasi           String    @default("")
  tanggalBerangkat String    @default("")
  harga            Int       @default(0)
  kuota            Int       @default(20)
  tersisa          Int       @default(20)
  status           String    @default("Tersedia")
  includes         String    @default("")
  tripCategory     String    @default("domestik")
  slug             String?
  hasDetail        Boolean   @default(false)
  // Fields untuk admin dashboard schedules (TripScheduleCalendar style)
  departureDate    DateTime?
  returnDate       DateTime?
  price            Int?
  quota            Int       @default(20)
  bookedCount      Int       @default(0)
  notes            String?
  notesEn          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tripCategory, status])
  @@index([packageId])
  @@index([departureDate])
}

model PrivateTripPricing {
  id          String   @id @default(uuid())
  packageId   String
  pax         Int
  price       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([packageId])
}
